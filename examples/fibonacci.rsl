fn fibonacci(x: u64) -> u64 {
    return if x == 0 then
        0
    else if x == 1 then
        1
    else
        fibonnaci(x - 1) + fibonacci(x - 2);
}

fn main() -> i64 {
    echo u64 fibonacci(0);
    echo u64 fibonacci(1);
    echo u64 fibonacci(10);
    echo u64 fibonacci(20);
    echo u64 fibonacci(100);
    return 0;
}
